# LLM provider + model
# PROVIDER values: anthropic | openai. Inferred from MODEL prefix if unset
# (claude-* → anthropic, gpt-*/o1-*/o3-*/o4-* → openai).
PROVIDER=anthropic
MODEL=claude-haiku-4-5-20251001

# API keys (set only the ones you'll actually use)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=

DISCORD_BOT_TOKEN=

EXTRACTION_MAX_TOKENS=2048

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=pearscarf
POSTGRES_PASSWORD=
POSTGRES_DB=pearscarf

# Qdrant vector store
QDRANT_URL=http://localhost:6333

# pgAdmin (optional — database UI at http://localhost:5050)
PGADMIN_EMAIL=admin@pearscarf.dev
PGADMIN_PASSWORD=admin

# Neo4j (knowledge graph — required for extraction pipeline)
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Timezone (for Day node date derivation)
TIMEZONE=America/Los_Angeles

# LangSmith observability (optional)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pears

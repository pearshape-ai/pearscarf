ANTHROPIC_API_KEY=sk-ant-your-key-here
DISCORD_BOT_TOKEN=

# Gmail OAuth (API-based transport) — optional, falls back to headless browser
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_POLL_INTERVAL=300

# Memory backend — "mem0" or "sqlite" (default: sqlite)
MEMORY_BACKEND=sqlite
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

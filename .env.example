ANTHROPIC_API_KEY=sk-ant-your-key-here
DISCORD_BOT_TOKEN=

# Extraction (optional — defaults to system MODEL)
EXTRACTION_MODEL=
EXTRACTION_MAX_TOKENS=2048

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=pearscaff
POSTGRES_PASSWORD=
POSTGRES_DB=pearscaff

# Qdrant vector store
QDRANT_URL=http://localhost:6333

# Gmail OAuth (API-based transport) — optional, falls back to headless browser
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_POLL_INTERVAL=300

# pgAdmin (optional — database UI at http://localhost:5050)
PGADMIN_EMAIL=admin@pearscaff.dev
PGADMIN_PASSWORD=admin

# Neo4j (optional — retained for future graph backend evaluation)
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# LangSmith observability (optional)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pears
